# Database Configuration (Supabase, Neon, or PostgreSQL)
POSTGRES_PRISMA_URL=postgresql://user:password@host:port/dbname
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:port/dbname

# Authentication
NEXTAUTH_SECRET=your-generated-secret-here
NEXTAUTH_URL=http://localhost:3000

# Stripe Payment Processing (Optional)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# MikroTik Router Integration (Optional)
MIKROTIK_IP=192.168.1.1
MIKROTIK_PORT=8728
MIKROTIK_USERNAME=admin
MIKROTIK_PASSWORD=password

# Alternative Payment Methods (Optional)
# MERCADOPAGO_ACCESS_TOKEN=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# Email Service (Optional)
# EMAIL_FROM=noreply@yourcompany.com
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# Application Settings
NODE_ENV=development
